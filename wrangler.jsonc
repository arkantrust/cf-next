{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cf-next",
  "compatibility_date": "2026-04-07",
  "compatibility_flags": ["nodejs_compat"],
  "main": "vinext/server/app-router-entry",
  "assets": {
    "directory": "dist/client",
    "not_found_handling": "none",
    "binding": "ASSETS",
  },
  "images": {
    "binding": "IMAGES",
  },
}
